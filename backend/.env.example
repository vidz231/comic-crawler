# ──────────────────────────────────────────────────────────────────────────────
# Comic Crawler — Environment Variables
#
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Crawler settings ──────────────────────────────────────────────────────────

# Max concurrent Playwright page fetches (keep low to avoid bans)
COMIC_CONCURRENCY=1

# Delay in seconds between fetcher requests (float)
COMIC_DOWNLOAD_DELAY=3.0

# Number of retries on failed fetches
COMIC_MAX_RETRIES=3

# Optional HTTP proxy list (JSON array of "http://user:pass@host:port" strings)
# Leave blank to disable proxying.
COMIC_PROXY_LIST=[]

# ── API settings ──────────────────────────────────────────────────────────────

# Rate limit per IP address (slowapi format, e.g. "60/minute", "100/hour")
COMIC_RATE_LIMIT=60/minute

# Allowed CORS origins.
# Accepts a JSON array, a single origin, or a comma-separated list.
# For production, set to your frontend URL: ["https://comics.example.com"]
COMIC_CORS_ORIGINS=["http://localhost:3000"]
